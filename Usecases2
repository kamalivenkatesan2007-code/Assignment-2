<!DOCTYPE html>
<html>
<head>
<title>Responsive Product Grid</title>

<style>

body{
font-family: Arial;
margin:0;
padding:20px;
background:#f4f4f4;
}

h1{
text-align:center;
margin-bottom:30px;
}

.product-grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
gap:20px;
}

.product-card{
background:white;
padding:15px;
border-radius:8px;
text-align:center;
box-shadow:0 0 8px rgba(0,0,0,0.2);
}

.product-card img{
width:100%;
border-radius:5px;
}

.price{
color:green;
font-weight:bold;
}

button{
margin-top:10px;
padding:8px 12px;
border:none;
background:#007BFF;
color:white;
border-radius:5px;
cursor:pointer;
}

button:hover{
background:#0056b3;
}

</style>

</head>

<body>

<h1>Product Catalog</h1>

<div class="product-grid">

<div class="product-card">
<img src="https://via.placeholder.com/200">
<h3>Product 1</h3>
<p class="price">₹999</p>
<button>Buy Now</button>
</div>

<div class="product-card">
<img src="https://via.placeholder.com/200">
<h3>Product 2</h3>
<p class="price">₹1299</p>
<button>Buy Now</button>
</div>

<div class="product-card">
<img src="https://via.placeholder.com/200">
<h3>Product 3</h3>
<p class="price">₹799</p>
<button>Buy Now</button>
</div>

<div class="product-card">
<img src="https://via.placeholder.com/200">
<h3>Product 4</h3>
<p class="price">₹1599</p>
<button>Buy Now</button>
</div>

<div class="product-card">
<img src="https://via.placeholder.com/200">
<h3>Product 5</h3>
<p class="price">₹899</p>
<button>Buy Now</button>
</div>

<div class="product-card">
<img src="https://via.placeholder.com/200">
<h3>Product 6</h3>
<p class="price">₹1099</p>
<button>Buy Now</button>
</div>

</div>

</body>
</html>
