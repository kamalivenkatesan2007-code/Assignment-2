<!DOCTYPE html>
<html>
<head>
<title>Image Upload and Preview</title>
<style>
body{font-family:Arial;margin:20px;}
#preview{margin-top:20px;width:300px;height:300px;border:1px solid #ccc;display:flex;align-items:center;justify-content:center;}
#preview img{max-width:100%;max-height:100%;}
</style>
</head>
<body>

<h2>Image Upload and Preview</h2>
<input type="file" id="imgInput" accept="image/*">
<div id="preview">Image will appear here</div>

<script>
document.getElementById("imgInput").addEventListener("change", function(){
  const file=this.files[0];
  if(file){
    const reader=new FileReader();
    reader.onload=function(e){
      document.getElementById("preview").innerHTML=`<img src="${e.target.result}">`;
    }
    reader.readAsDataURL(file);
  }
});
</script>

</body>
</html>
